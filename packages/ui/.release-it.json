{
  "hooks": {
    "after:bump": ["pnpm run build"]
  },
  "git": {
    "commitMessage": "chore: release v${version} [skip ci]",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}"
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": true,
    "publishPath": "."
  }
}
