{
  "name": "piece-ui-monorepo",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:docs": "pnpm --filter piece-ui-docs dev",
    "dev:ui": "pnpm --filter piece-ui dev",
    "lint": "turbo run lint",
    "storybook": "pnpm --filter piece-ui storybook",
    "storybook:build": "pnpm --filter piece-ui storybook:build",
    "release": "pnpm --filter piece-ui release"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
