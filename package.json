{
  "name": "piece-ui",
  "version": "1.0.0-alpha.2",
  "author": {
    "name": "aymane atigui",
    "url": "https://x.com/pieceui"
  },
  "description": "Piece UI is a React component library that helps you build accessible and responsive web applications.",
  "repository": {
    "type": "git",
    "url": "https://github.com/aymaneatigui/piece-ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "components",
    "react",
    "ui",
    "tailwind",
    "piece-ui"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "release": "release-it"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "release-it": "^17.0.1",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "framer-motion": "^11.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
